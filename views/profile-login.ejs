<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#050816" />
    <title>Resell Tracker · <%= profile.name %> login</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-shell app-shell-visible app-shell-profiles">
      <header class="app-header app-header-centered">
        <div class="app-header-left">
          <div class="app-logo app-logo-splash">RT</div>
          <div class="app-title-block">
            <h1 class="app-title">Resell Tracker</h1>
            <p class="app-subtitle">
              Sign in to <strong><%= profile.name %></strong>&apos;s profile
            </p>
          </div>
        </div>
      </header>

      <main class="app-main">
        <section class="dashboard-section">
          <div class="card card-highlight profiles-card">
            <div class="profile-login-header">
              <div class="profile-avatar profile-avatar-large">
                <span><%= profile.name.charAt(0).toUpperCase() %></span>
              </div>
              <div class="profile-info">
                <p class="profile-name"><%= profile.name %></p>
                <p class="profile-meta">
                  Enter password to access this profile.
                </p>
              </div>
            </div>

            <form
              class="modal-form profile-login-form"
              action="/profiles/<%= profile.id %>/login"
              method="POST"
              novalidate
            >
              <div class="form-group">
                <label for="password" class="form-label">
                  Password
                </label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  class="input"
                  autocomplete="off"
                  required
                  placeholder="Enter password"
                />
              </div>

              <% if (error) { %>
                <p class="empty-state-text">
                  <%= error %>
                </p>
              <% } %>

              <div class="modal-footer">
                <a href="/profiles" class="btn btn-ghost">Back</a>
                <button type="submit" class="btn btn-primary">
                  Continue
                </button>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>

