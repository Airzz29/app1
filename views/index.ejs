<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0b0b11" />
    <title>Resell Tracker</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-splash" id="appSplash">
      <div class="app-splash-inner">
        <div class="app-logo app-logo-splash">RT</div>
        <div class="app-splash-text">
          <p class="app-splash-label">Tracker</p>
          <p class="app-splash-subtitle">Loading your dashboard</p>
        </div>
        <div class="app-splash-loader">
          <span class="app-splash-dot"></span>
          <span class="app-splash-dot"></span>
          <span class="app-splash-dot"></span>
        </div>
      </div>
    </div>

    <div class="app-shell app-shell-hidden" id="appShell">
      <%- include('partials/header') %>

      <main class="app-main">
        <%- include('partials/dashboard', {
          activeHauls,
          expiredHauls,
          previousHauls,
          stats,
          recentSales,
          todos,
          plans,
          openIssues,
          latestSharedNote,
          upcomingHauls
        }) %>
      </main>

      <%- include('partials/haulModal') %>
      <%- include('partials/upcomingHaulModal') %>
    </div>

    <script src="/js/main.js"></script>
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker
            .register('/sw.js')
            .catch(function (err) {
              console.error('Service worker registration failed', err);
            });
        });
      }
    </script>
  </body>
</html>
