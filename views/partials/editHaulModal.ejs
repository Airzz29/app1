<div
  id="editModal-<%= haul.id %>"
  class="modal-backdrop"
  aria-hidden="true"
  data-modal
>
  <div
    class="modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="editModalTitle-<%= haul.id %>"
  >
    <div class="modal-header">
      <div>
        <p class="label">Edit haul</p>
        <h2
          id="editModalTitle-<%= haul.id %>"
          class="modal-title"
        >
          <%= haul.name %>
        </h2>
      </div>
      <button
        class="icon-button"
        type="button"
        aria-label="Close"
        data-modal-close
      >
        ✕
      </button>
    </div>

    <form
      class="modal-form"
      action="/hauls/<%= haul.id %>/edit"
      method="POST"
      enctype="multipart/form-data"
      novalidate
    >
      <% if (typeof from !== 'undefined' && from === 'track-hauls') { %>
        <input type="hidden" name="from" value="track-hauls" />
      <% } %>
      <div class="form-group">
        <label
          for="editHaulName-<%= haul.id %>"
          class="form-label"
        >
          Haul name<span class="required">*</span>
        </label>
        <input
          id="editHaulName-<%= haul.id %>"
          name="haulName"
          type="text"
          class="input"
          required
          autocomplete="off"
          value="<%= haul.name %>"
        />
      </div>

      <div class="form-group">
        <label
          for="editGenre-<%= haul.id %>"
          class="form-label"
        >
          Genre
        </label>
        <input
          id="editGenre-<%= haul.id %>"
          name="genre"
          type="text"
          class="input"
          autocomplete="off"
          value="<%= haul.genre || '' %>"
        />
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label
            for="editItemCount-<%= haul.id %>"
            class="form-label"
          >
            Items
          </label>
          <input
            id="editItemCount-<%= haul.id %>"
            name="itemCount"
            type="number"
            min="0"
            inputmode="numeric"
            class="input"
            value="<%= haul.totalItems != null ? haul.totalItems : '' %>"
          />
        </div>

        <div class="form-group">
          <label
            for="editDuration-<%= haul.id %>"
            class="form-label"
          >
            Sell days
          </label>
          <input
            id="editDuration-<%= haul.id %>"
            name="durationDays"
            type="number"
            min="0"
            inputmode="numeric"
            class="input"
            value="<%= haul.duration_days != null ? haul.duration_days : '' %>"
          />
        </div>
      </div>

      <div class="form-group">
        <label
          for="editCost-<%= haul.id %>"
          class="form-label"
        >
          Cost (total)
        </label>
        <div class="input-with-prefix">
          <span class="input-prefix">$</span>
          <input
            id="editCost-<%= haul.id %>"
            name="cost"
            type="number"
            min="0"
            step="0.01"
            inputmode="decimal"
            class="input input-no-padding-left"
            value="<%= haul.cost != null ? haul.cost : '' %>"
          />
        </div>
      </div>

      <div class="form-group">
        <label
          for="editTrackingNumber-<%= haul.id %>"
          class="form-label"
        >
          Tracking number
        </label>
        <input
          id="editTrackingNumber-<%= haul.id %>"
          name="trackingNumber"
          type="text"
          class="input"
          autocomplete="off"
          placeholder="e.g. Australia Post tracking (optional)"
          value="<%= haul.tracking_number || '' %>"
        />
      </div>

      <div class="form-group">
        <label
          for="editHaulImage-<%= haul.id %>"
          class="form-label"
        >
          Haul image
        </label>
        <input
          id="editHaulImage-<%= haul.id %>"
          name="haulImage"
          type="file"
          accept="image/*"
          class="input"
        />
      </div>

      <div class="modal-footer">
        <button
          type="button"
          class="btn btn-ghost"
          data-modal-close
        >
          Cancel
        </button>
        <button type="submit" class="btn btn-primary">
          Save changes
        </button>
      </div>
    </form>
  </div>
</div>
