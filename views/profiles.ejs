<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0b0b11" />
    <title>Resell Tracker · Choose profile</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-shell app-shell-visible app-shell-profiles">
      <header class="app-header app-header-centered">
        <div class="app-header-left">
          <div class="app-logo app-logo-splash">RT</div>
          <div class="app-title-block">
            <p class="label">Selling Dashboard</p>
            <h1 class="profiles-welcome-title">Welcome back</h1>
            <p class="profiles-welcome-sub">Choose a profile to continue</p>
          </div>
        </div>
      </header>

      <main class="app-main">
        <section class="dashboard-section">
          <div class="card card-highlight profiles-card">
            <p class="label">Profiles</p>
            <h2 class="card-title">Sign in</h2>
            <p class="empty-state-text">
              Each profile keeps hauls, sales, planning, and tools separate.
            </p>

            <div class="profiles-grid">
              <% profiles.forEach(function (profile) { %>
                <a
                  href="/profiles/<%= profile.id %>/login"
                  class="profile-tile"
                >
                  <div class="profile-avatar">
                    <span><%= profile.name.charAt(0).toUpperCase() %></span>
                  </div>
                  <div class="profile-info">
                    <p class="profile-name"><%= profile.name %></p>
                    <p class="profile-meta">
                      Personalised hauls, stats & planning
                    </p>
                  </div>
                </a>
              <% }); %>
            </div>
          </div>
        </section>
      </main>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>

