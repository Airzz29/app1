<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0b0b11" />
    <title>Resell Tracker · Planning</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-shell app-shell-visible">
      <%- include('partials/header') %>

      <main class="app-main">
        <section class="dashboard">
          <section class="dashboard-section">
            <div class="card card-highlight">
              <div class="section-header section-header-tight">
                <div>
                  <p class="label">Planning</p>
                  <h2 class="card-title"><%= plan.title %></h2>
                </div>
                <div class="planning-detail-actions">
                  <a
                    href="/planning/<%= plan.id %>/edit"
                    class="btn btn-primary btn-compact"
                  >
                    Edit
                  </a>
                  <a href="/planning" class="btn btn-secondary btn-compact">
                    Back to plans
                  </a>
                </div>
              </div>

              <div class="planning-view">
                <div class="planning-view-meta">
                  <% if (plan.target_date) { %>
                    <span class="planning-view-meta-item">Target date: <%= plan.target_date %></span>
                  <% } else { %>
                    <span class="planning-view-meta-item">No target date</span>
                  <% } %>
                </div>

                <div class="planning-view-section">
                  <h3 class="section-title">What to buy</h3>
                  <pre class="planning-raw" data-planning-raw="whatToBuy"><%= plan.what_to_buy || '' %></pre>
                  <div class="planning-preview planning-preview-view" data-planning-preview="whatToBuy"></div>
                </div>

                <div class="planning-view-section">
                  <h3 class="section-title">Notes</h3>
                  <pre class="planning-raw" data-planning-raw="details"><%= plan.details || '' %></pre>
                  <div class="planning-preview planning-preview-view" data-planning-preview="details"></div>
                </div>
              </div>
            </div>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/main.js"></script>
    <script src="/js/planning-editor.js"></script>
  </body>
</html>

