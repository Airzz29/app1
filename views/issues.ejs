<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0b0b11" />
    <title>Resell Tracker · Issues</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-shell app-shell-visible">
      <%- include('partials/header') %>

      <main class="app-main">
        <section class="dashboard">
          <section class="dashboard-section">
            <div class="card card-highlight">
              <div class="section-header section-header-tight">
                <div>
                  <p class="label">Issues</p>
                  <h2 class="card-title">All issues & disputes</h2>
                </div>
                <a href="/" class="btn btn-secondary btn-compact">
                  Back to dashboard
                </a>
              </div>

              <form
                class="modal-form planning-form"
                action="/issues"
                method="POST"
                novalidate
              >
                <div class="form-grid">
                  <div class="form-group">
                    <label for="issuePlatform" class="form-label">
                      Platform
                    </label>
                    <select
                      id="issuePlatform"
                      name="platform"
                      class="input"
                    >
                      <option value="">Select platform</option>
                      <option value="Marketplace">Facebook Marketplace</option>
                      <option value="Depop">Depop</option>
                      <option value="eBay">eBay</option>
                      <option value="Gumtree">Gumtree</option>
                      <option value="Vinted">Vinted</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="issueOrderRef" class="form-label">
                      Order / item
                    </label>
                    <input
                      id="issueOrderRef"
                      name="orderRef"
                      type="text"
                      class="input"
                      autocomplete="off"
                      placeholder="e.g. Order #1234, Jordan 4 Oreo"
                    />
                  </div>
                </div>

                <div class="form-group">
                  <label for="issueDueAt" class="form-label">
                    Due / escalation time
                  </label>
                  <input
                    id="issueDueAt"
                    name="dueAt"
                    type="datetime-local"
                    class="input"
                  />
                </div>

                <div class="form-group">
                  <label for="issueDescription" class="form-label">
                    Problem description<span class="required">*</span>
                  </label>
                  <textarea
                    id="issueDescription"
                    name="description"
                    rows="3"
                    class="input planning-textarea"
                    required
                    placeholder="Describe the dispute, claim, refund problem, or buyer issue."
                  ></textarea>
                </div>

                <div class="modal-footer">
                  <button type="submit" class="btn btn-primary">
                    Log issue
                  </button>
                </div>
              </form>
            </div>
          </section>

          <section class="dashboard-section">
            <div class="section-header">
              <h3 class="section-title">Current issues</h3>
            </div>

            <% const openIssues = (issues || []).filter(function (i) { return i.status !== 'resolved'; }); %>
            <% if (openIssues.length === 0) { %>
              <p class="empty-state-text">
                You don’t have any active issues. When you do, they’ll appear here.
              </p>
            <% } else { %>
              <div class="haul-list haul-list-subtle">
                <% openIssues.forEach(function (issue) { %>
                  <article class="haul-row haul-row-card issue-row">
                    <div class="haul-row-main">
                      <p class="haul-name">
                        <%= issue.platform || 'Issue' %>
                        <% if (issue.order_ref) { %>
                          · <span class="issue-order-ref"><%= issue.order_ref %></span>
                        <% } %>
                      </p>
                      <p class="haul-progress-label">
                        <%= issue.description %>
                      </p>
                      <p class="haul-progress-label haul-progress-label-muted">
                        <% if (issue.due_at) { %>
                          <span
                            class="countdown countdown-issue"
                            data-countdown-end="<%= issue.due_at %>"
                          >
                            Calculating…
                          </span>
                        <% } else { %>
                          No due time set
                        <% } %>
                      </p>
                    </div>
                    <div class="haul-row-stats haul-row-stats-vertical">
                      <form
                        action="/issues/<%= issue.id %>/resolve?from=issues"
                        method="POST"
                      >
                        <button type="submit" class="btn btn-primary btn-compact">
                          Mark resolved
                        </button>
                      </form>
                    </div>
                  </article>
                <% }); %>
              </div>
            <% } %>
          </section>

          <section class="dashboard-section">
            <div class="section-header">
              <h3 class="section-title">Resolved history</h3>
            </div>

            <% const resolvedIssues = (issues || []).filter(function (i) { return i.status === 'resolved'; }); %>
            <% if (resolvedIssues.length === 0) { %>
              <p class="empty-state-text">
                No resolved issues yet. Once you close issues, they will appear here.
              </p>
            <% } else { %>
              <div class="haul-list haul-list-subtle planning-list">
                <% resolvedIssues.forEach(function (issue) { %>
                  <article class="haul-row haul-row-previous issue-row">
                    <div class="haul-row-main">
                      <p class="haul-name">
                        <%= issue.platform || 'Issue' %>
                        <% if (issue.order_ref) { %>
                          · <span class="issue-order-ref"><%= issue.order_ref %></span>
                        <% } %>
                      </p>
                      <p class="haul-progress-label haul-progress-label-muted">
                        <%= issue.description %>
                      </p>
                    </div>
                  </article>
                <% }); %>
              </div>
            <% } %>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>

