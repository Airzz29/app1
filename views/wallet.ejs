<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0b0b11" />
    <title>Resell Tracker · Wallet</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-shell app-shell-visible">
      <%- include('partials/header') %>

      <main class="app-main">
        <section class="dashboard">
          <section class="dashboard-section">
            <div class="card card-highlight">
              <div class="section-header section-header-tight">
                <div>
                  <p class="label">Wallet</p>
                  <h2 class="card-title">Balance & activity</h2>
                </div>
                <a href="/" class="btn btn-secondary btn-compact">
                  Back to dashboard
                </a>
              </div>

              <div class="wallet-summary-grid">
                <div class="wallet-summary-main">
                  <p class="metric-label">Current balance</p>
                  <p class="wallet-balance" data-wallet-balance>
                    $<%= walletSummary.balance.toFixed(2) %>
                  </p>
                </div>
                <div class="wallet-summary-stats">
                  <div class="wallet-summary-row">
                    <span>Total added</span>
                    <span>$<%= walletSummary.totalAdded.toFixed(2) %></span>
                  </div>
                  <div class="wallet-summary-row">
                    <span>Total withdrawn</span>
                    <span>$<%= walletSummary.totalWithdrawn.toFixed(2) %></span>
                  </div>
                  <div class="wallet-summary-row">
                    <span>Sales revenue</span>
                    <span>$<%= walletSummary.totalRevenueFromSales.toFixed(2) %></span>
                  </div>
                  <div class="wallet-summary-row">
                    <span>Haul spend</span>
                    <span>$<%= walletSummary.totalSpentOnHauls.toFixed(2) %></span>
                  </div>
                </div>
              </div>

              <div class="wallet-actions">
                <% const balanceIsZero = walletSummary.balance >= -0.005 && walletSummary.balance <= 0.005; %>
                <% if (balanceIsZero) { %>
                  <button
                    type="button"
                    class="btn btn-primary wallet-action-btn"
                    data-modal-target="#walletStartingModal"
                  >
                    Set Wallet Balance
                  </button>
                <% } else { %>
                  <button
                    type="button"
                    class="btn btn-secondary wallet-action-btn"
                    data-modal-target="#walletResetModal"
                  >
                    Reset Wallet
                  </button>
                  <button
                    type="button"
                    class="btn btn-secondary wallet-action-btn"
                    data-modal-target="#walletWithdrawModal"
                  >
                    Withdraw money
                  </button>
                  <button
                    type="button"
                    class="btn btn-primary wallet-action-btn"
                    data-modal-target="#walletAddModal"
                  >
                    Add money
                  </button>
                <% } %>
              </div>

              <div class="wallet-profit">
                <p class="metric-label">Lifetime profit</p>
                <p class="wallet-profit-value">
                  $<%= walletSummary.profitFromStats.toFixed(2) %>
                </p>
              </div>
            </div>
          </section>

          <section class="dashboard-section">
            <div class="section-header">
              <h3 class="section-title">Transaction history</h3>
            </div>

            <% if (!walletTransactions || walletTransactions.length === 0) { %>
              <p class="empty-state-text">
                No wallet activity yet. Starting balance, haul purchases, sales
                revenue, and manual moves will appear here.
              </p>
            <% } else { %>
              <ul class="wallet-list">
                <% walletTransactions.forEach(function (tx) { %>
                  <% const amt = tx.amount || 0; %>
                  <% const isCredit = amt >= 0; %>
                  <li class="wallet-item">
                    <div class="wallet-item-main">
                      <p class="wallet-item-title">
                        <span class="wallet-amount <%= isCredit ? 'wallet-amount-credit' : 'wallet-amount-debit' %>">
                          <%= isCredit ? '+' : '-' %>$<%= Math.abs(amt).toFixed(2) %>
                        </span>
                        <span class="wallet-type">
                          <%= tx.type === 'wallet_reset' ? 'Wallet reset' : tx.type.replace(/_/g, ' ') %>
                        </span>
                      </p>
                      <p class="wallet-item-desc">
                        <%= tx.description %>
                      </p>
                      <p class="wallet-item-meta">
                        <% if (tx.related_haul_id) { %>
                          <span>Haul #<%= tx.related_haul_id %></span>
                        <% } %>
                        <% if (tx.related_item_id) { %>
                          <% if (tx.related_haul_id) { %>
                            <span>&middot;</span>
                          <% } %>
                          <span>Sale #<%= tx.related_item_id %></span>
                        <% } %>
                        <% if (tx.created_at) { %>
                          <% if (tx.related_haul_id || tx.related_item_id) { %>
                            <span>&middot;</span>
                          <% } %>
                          <span><%= tx.created_at %></span>
                        <% } %>
                      </p>
                    </div>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </section>
        </section>
      </main>
    </div>

    <div
      id="walletStartingModal"
      class="modal-backdrop"
      aria-hidden="true"
      data-modal
    >
      <div
        class="modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="walletStartingTitle"
      >
        <div class="modal-header">
          <div>
            <p class="label">Wallet</p>
            <h2 id="walletStartingTitle" class="modal-title">
              Set starting balance
            </h2>
          </div>
          <button
            class="icon-button"
            type="button"
            aria-label="Close"
            data-modal-close
          >
            ✕
          </button>
        </div>
        <form
          id="walletStartingForm"
          class="modal-form"
          action="/wallet/starting"
          method="POST"
          novalidate
        >
          <div class="form-group">
            <label for="startingAmount" class="form-label">
              Starting amount
            </label>
            <div class="input-with-prefix">
              <span class="input-prefix">$</span>
              <input
                id="startingAmount"
                name="amount"
                type="number"
                min="0"
                step="0.01"
                inputmode="decimal"
                class="input input-no-padding-left"
                placeholder="e.g. 1300.00"
                required
              />
            </div>
          </div>
          <div class="form-group">
            <label for="startingDescription" class="form-label">
              Description<span class="required">*</span>
            </label>
            <input
              id="startingDescription"
              name="description"
              type="text"
              class="input"
              required
              autocomplete="off"
              placeholder="e.g. Initial balance"
            />
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-ghost"
              data-modal-close
            >
              Cancel
            </button>
            <button type="submit" class="btn btn-primary">
              Save starting balance
            </button>
          </div>
        </form>
      </div>
    </div>

    <div
      id="walletAddModal"
      class="modal-backdrop"
      aria-hidden="true"
      data-modal
    >
      <div
        class="modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="walletAddTitle"
      >
        <div class="modal-header">
          <div>
            <p class="label">Wallet</p>
            <h2 id="walletAddTitle" class="modal-title">
              Add money
            </h2>
          </div>
          <button
            class="icon-button"
            type="button"
            aria-label="Close"
            data-modal-close
          >
            ✕
          </button>
        </div>
        <form
          id="walletAddForm"
          class="modal-form"
          action="/wallet/add"
          method="POST"
          novalidate
        >
          <div class="form-group">
            <label for="addAmount" class="form-label">
              Amount<span class="required">*</span>
            </label>
            <div class="input-with-prefix">
              <span class="input-prefix">$</span>
              <input
                id="addAmount"
                name="amount"
                type="number"
                min="0"
                step="0.01"
                inputmode="decimal"
                class="input input-no-padding-left"
                placeholder="e.g. 250.00"
                required
              />
            </div>
          </div>
          <div class="form-group">
            <label for="addDescription" class="form-label">
              Description<span class="required">*</span>
            </label>
            <input
              id="addDescription"
              name="description"
              type="text"
              class="input"
              required
              autocomplete="off"
              placeholder="e.g. Added funds from bank"
            />
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-ghost"
              data-modal-close
            >
              Cancel
            </button>
            <button type="submit" class="btn btn-primary">
              Add money
            </button>
          </div>
        </form>
      </div>
    </div>

    <div
      id="walletResetModal"
      class="modal-backdrop"
      aria-hidden="true"
      data-modal
    >
      <div
        class="modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="walletResetTitle"
      >
        <div class="modal-header">
          <div>
            <p class="label">Wallet</p>
            <h2 id="walletResetTitle" class="modal-title">
              Reset wallet
            </h2>
          </div>
          <button
            class="icon-button"
            type="button"
            aria-label="Close"
            data-modal-close
          >
            ✕
          </button>
        </div>
        <form
          id="walletResetForm"
          class="modal-form"
          action="/wallet/reset"
          method="POST"
          novalidate
        >
          <p class="wallet-reset-intro">
            This will set your wallet balance to $0 and add a reset entry in your transaction history. You can then set a new starting balance.
          </p>
          <div class="form-group">
            <label for="resetDescription" class="form-label">
              Note (optional)
            </label>
            <input
              id="resetDescription"
              name="description"
              type="text"
              class="input"
              autocomplete="off"
              placeholder="e.g. Wallet reset to start fresh"
            />
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-ghost"
              data-modal-close
            >
              Cancel
            </button>
            <button type="submit" class="btn btn-danger">
              Reset wallet to $0
            </button>
          </div>
        </form>
      </div>
    </div>

    <div
      id="walletWithdrawModal"
      class="modal-backdrop"
      aria-hidden="true"
      data-modal
    >
      <div
        class="modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="walletWithdrawTitle"
      >
        <div class="modal-header">
          <div>
            <p class="label">Wallet</p>
            <h2 id="walletWithdrawTitle" class="modal-title">
              Withdraw money
            </h2>
          </div>
          <button
            class="icon-button"
            type="button"
            aria-label="Close"
            data-modal-close
          >
            ✕
          </button>
        </div>
        <form
          id="walletWithdrawForm"
          class="modal-form"
          action="/wallet/withdraw"
          method="POST"
          novalidate
        >
          <div class="form-group">
            <label for="withdrawAmount" class="form-label">
              Amount<span class="required">*</span>
            </label>
            <div class="input-with-prefix">
              <span class="input-prefix">$</span>
              <input
                id="withdrawAmount"
                name="amount"
                type="number"
                min="0"
                step="0.01"
                inputmode="decimal"
                class="input input-no-padding-left"
                placeholder="e.g. 100.00"
                required
              />
            </div>
          </div>
          <div class="form-group">
            <label for="withdrawDescription" class="form-label">
              Description<span class="required">*</span>
            </label>
            <input
              id="withdrawDescription"
              name="description"
              type="text"
              class="input"
              required
              autocomplete="off"
              placeholder="e.g. Cash out to bank"
            />
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-ghost"
              data-modal-close
            >
              Cancel
            </button>
            <button type="submit" class="btn btn-primary">
              Withdraw
            </button>
          </div>
        </form>
      </div>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>

