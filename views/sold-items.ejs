<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#050816" />
    <title>Resell Tracker · Sold items</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/jpeg" href="/icon.jpg" />
    <link rel="apple-touch-icon" href="/icon.jpg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="app-body">
    <div class="app-shell app-shell-visible">
      <%- include('partials/header') %>

      <main class="app-main">
        <section class="dashboard">
          <section class="dashboard-section">
            <div class="card card-highlight">
              <div class="section-header section-header-tight">
                <div>
                  <p class="label">Sales</p>
                  <h2 class="card-title">All sold items</h2>
                </div>
                <a href="/" class="btn btn-secondary btn-compact">
                  Back to dashboard
                </a>
              </div>

              <form class="tools-filters" method="GET" action="/sold-items">
                <div class="tools-filters-main">
                  <input
                    type="text"
                    name="q"
                    value="<%= query || '' %>"
                    placeholder="Search by item, haul, or platform"
                    class="input"
                    autocomplete="off"
                  />
                </div>
                <div class="tools-filters-side">
                  <select
                    name="sort"
                    class="input"
                    onchange="this.form.submit()"
                  >
                    <option value="date_desc" <%= sort === 'date_desc' ? 'selected' : '' %>>
                      Newest first
                    </option>
                    <option value="date_asc" <%= sort === 'date_asc' ? 'selected' : '' %>>
                      Oldest first
                    </option>
                    <option value="name" <%= sort === 'name' ? 'selected' : '' %>>
                      Name (A–Z)
                    </option>
                  </select>
                  <button type="submit" class="btn btn-secondary btn-compact">
                    Search
                  </button>
                </div>
              </form>
            </div>
          </section>

          <section class="dashboard-section">
            <% if (!sales || sales.length === 0) { %>
              <p class="empty-state-text">
                No sold items recorded yet for this profile.
              </p>
            <% } else { %>
              <ul class="wallet-list">
                <% sales.forEach(function (sale) { %>
                  <li class="wallet-item">
                    <div class="wallet-item-main">
                      <p class="wallet-item-title">
                        <span class="wallet-amount wallet-amount-credit">
                          $<%= (sale.sold_price || 0).toFixed(2) %>
                        </span>
                        <span class="wallet-type">
                          <%= sale.item_name || 'Item' %>
                        </span>
                      </p>
                      <p class="wallet-item-desc">
                        <% if (sale.haul_name) { %>
                          From haul "<%= sale.haul_name %>"
                        <% } %>
                        <% if (sale.platform) { %>
                          <span>&middot;</span>
                          <span>Platform: <%= sale.platform %></span>
                        <% } %>
                      </p>
                      <p class="wallet-item-meta">
                        <% if (sale.sold_at) { %>
                          <span><%= sale.sold_at %></span>
                        <% } %>
                      </p>
                    </div>
                    <div class="tools-actions">
                      <a
                        href="/hauls/<%= sale.haul_id %>"
                        class="btn btn-secondary btn-compact"
                      >
                        View haul
                      </a>
                    </div>
                  </li>
                <% }); %>
              </ul>
            <% } %>
          </section>
        </section>
      </main>
    </div>

    <script src="/js/main.js"></script>
  </body>
</html>

